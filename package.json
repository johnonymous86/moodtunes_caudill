{
  "name": "moodtunes",
  "version": "0.1.0",
  "private": true,
  "config": {
    "DB_NAME": "moodtunes"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "mongo": "npm run mongo:restart && npm run mongo:check",
    "mongo:restart": "npm run mongo:stop; npm run mongo:start",
    "mongo:start": "docker run --rm -d -p 27017:27017 --name=mongo-sandbox -e MONGO_INITDB_DATABASE=$npm_package_config_DB_NAME mongo:6",
    "mongo:stop": "docker container stop mongo-sandbox",
    "mongo:shell": "docker exec -it mongo-sandbox mongosh",
    "mongo:check": "until docker exec -it mongo-sandbox mongosh --eval \"use $npm_package_config_DB_NAME;\"; do echo ...; sleep 1; done"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "next-auth": "^4.24.7",
    "mongoose": "^8.4.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.4",
    "postcss": "^8",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5"
  }
}
